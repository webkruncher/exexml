	inline void NodeMapper::CloseNode(JsonMapNode& node,stringtype& text,NodeMapBase& xmap)
	{
		char CloseChar( 0 );
		switch ( node.type )
		{
			case JsonFamilyUtils::JsonMapNode::openBrace : CloseChar = JsonFamilyUtils::JsonMapNode::closeBrace; break;
			case JsonFamilyUtils::JsonMapNode::openBracket : CloseChar = JsonFamilyUtils::JsonMapNode::closeBracket; break;
			default: JsonError( "Cannot open node" );
		}
		NodeMapBase::reverse_iterator relatives(xmap.rbegin());
		if (&*relatives!=&node) JsonError("this is impossible");
		relatives++;
		if (relatives==xmap.rend()) JsonError("bad relative (1) ",&text[node.pos]);

		if ( CloseChar == '}' )
			if ( ((*relatives).bDone) || ((*relatives).type!=JsonMapNode::closeBrace) ) JsonError("bad relative (2)",&text[node.pos]);
		if ( CloseChar == ']' )
			if ( ((*relatives).bDone) || ((*relatives).type!=JsonMapNode::closeBracket) ) JsonError("bad relative (3)",&text[node.pos]);

		JsonMapNode& mn=*relatives;
		mn.Mark2=&node;
		node.Mark1=&mn;
		node.Mark2=&node;
		node.name=mn.name;
		node.bDone=true;

	}


	inline void NodeMapper::Relate(JsonMapNode& node,stringtype& text,NodeMapBase& xmap)
	{
cerr << "Relating node: " << node.pos << endl;
		NodeMapBase::reverse_iterator relatives=xmap.rbegin();
		if (&*relatives!=&node) JsonError("invalid call to Excavate(...)");
		relatives++;
		if (!(relatives==xmap.rend())) 
		{
			JsonMapNode& mn=*relatives;
			mn.next=&node;
			node.prev=&mn;
cerr << "NodeMapper::Relate: Setting relatives " << endl;
		} else
cerr << "NodeMapper::Relate: NOT Setting relatives " << endl;
	}

	inline void NodeMapper::ResolveType(JsonMapNode& node,stringtype& text,NodeMapBase& xmap)
	{
		chartype& chr(text[node.pos]); 
cout << "Resolving " << chr << endl;
		switch ( chr )
		{
			case '{' : node.type=JsonFamilyUtils::JsonMapNode::openBrace; break;
			case '}' : node.type=JsonFamilyUtils::JsonMapNode::closeBrace; break;
			case '[' : node.type=JsonFamilyUtils::JsonMapNode::openBracket; break;
			case ']' : node.type=JsonFamilyUtils::JsonMapNode::closeBracket; break;
			default: JsonError( "Bad node" );
		}

	}


	inline void NodeMapper::OpenNode(JsonMapNode& node,stringtype& text,NodeMapBase& xmap)
	{
		if ((node.pos+1)>text.size()) JsonError("Invalid Json - node pos > text size on end");
		node.name="NoNameYet";
		node.Mark2=&node;
	}

	inline void NodeMapper::Excavate(JsonMapNode& node,stringtype& text,NodeMapBase& xmap)
	{
cerr << "Relate" << endl;
		Relate(node,text,xmap);
cerr << "ResolveType" << endl;
		ResolveType(node,text,xmap);
cerr << "Switch:" << node.type << endl;
		switch(node.type)
		{
			case JsonMapNode::openBrace:		OpenNode(node,text,xmap); break;
			case JsonMapNode::closeBrace:		CloseNode(node,text,xmap); break;
			case JsonMapNode::openBracket:		OpenNode(node,text,xmap); break;
			case JsonMapNode::closeBracket:		CloseNode(node,text,xmap); break;
			default: 					JsonError("unknownTagSymbol");
		}
	}
