	class JsonException : public std::exception
	{
		friend void JsonError(const chartype* a);
		friend void JsonError(const chartype* a,const chartype* b);
		JsonException(){}
		virtual ~JsonException() throw() {}
		JsonException(chartype* a,chartype* b)  { stringstreamtype ss;ss<<a<<" "<<b; msg=ss.str();}
		public: virtual const chartype* what() const throw() {return msg.c_str();}
		private: string msg;
	};

	inline void JsonError(const chartype* a){throw JsonException(const_cast<chartype*>(a),NULL);}
	inline void JsonError(const chartype* a,const chartype* b) {throw JsonException(const_cast<chartype*>(a),const_cast<chartype*>(b));}
