	class Json 
	{
	public:
		Json() : Root(NULL) {}
		Json(istream& in) : Root(NULL) {Load(in);}
		Json(const JsonFamily::Json& a) : Root(NULL) {Copy(a);}
		operator JsonNode& () { if (!Root) JsonError("No root node"); return *Root; }
		void TabLevel(int tl) { if (!Root) JsonError("No root node"); Root->SetTabLevel(tl);}
		const Json& operator=(const Json& a)
		{
			if (&a==this) return *this; 
			if (Root) delete Root; Root=NULL;
			const Json& ret=Copy(a);
			return ret;
		}

		virtual ~Json(){if (Root) delete Root; Root=NULL;Headers.clear();Comments.clear();}
		virtual bool operator()() {if (Root) return (*Root)(); return false;}
		virtual void Load(istream& in,JsonFamily::JsonNode* _root=NULL)
		{
			if (_root) Root=_root;
			else 
			{
				if (Root) delete Root;
				Root = NewNode(*this,"root");
			}
			if (!Root) JsonError("out of memory");
			stringtype text; stringstreamtype ss;
			while (!in.eof())
			{
				string line;
				getline(in,line);
				ss<<line<<endl;
			}
			text=ss.str().c_str();
			Root->Load(text);
			text.clear();
		}

		virtual void Load(char* txt)
		{
			Root = NewNode(*this,"root");
			if (!Root) JsonError("out of memory");
			stringtype text(txt);
			Root->Load(text);
		}

		virtual void Load(stringtype& text,JsonFamily::JsonNode* _root=NULL)
		{
			if (_root) Root=_root;
			else Root = NewNode(*this,"root");
			if (!Root) JsonError("out of memory");
			Root->Load(text);
		}
		JsonNode *Root;
		friend ostream& operator<<(ostream& o,Json& Json);
        	list<stringtype> Headers,Comments;
		virtual JsonNode* NewNode(Json& _doc,stringtype name)
		{
			JsonNode* n = new JsonNode(_doc,NULL,name); 
			if (!n) JsonError("Can't create node"); 
			return n;
		}
		virtual const Json& Copy(const Json& a)
		{
			if (Root) JsonError("Trying to copy Json over Json");
			Headers=a.Headers;
			if (!a.Root) return *this;
			Root=NewNode(*this,a.Root->name);
			(*Root)=(*a.Root);
			return *this;
		}
	private:
		
	protected:
		virtual void operator()(istream& i,ostream& o)
		{
			if (Root) 
			{
				(*Root)(i,o); 
			}
		}
		virtual ostream& operator<<(ostream& o)
		{
			if (Root) 
			{
				for (list<string>::iterator it=Headers.begin();it!=Headers.end();it++)
					o<<(*it)<<endl;
				o<<(*Root); 
			}
			return o;
		}
	};
