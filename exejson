	class JsonNode : public JsonFamilyUtils::JsonNodeGuts
	{
		friend class Json;
		virtual JsonNodeBase* NewNode(Json& _doc,JsonNodeBase* parent,stringtype name)
			{return static_cast<JsonNodeBase*>(new JsonNode(_doc,parent,name));}

		friend ostream& operator<<(ostream& o,JsonNode& Jsonnode);
	public:
		virtual operator Json* () { return NULL;}
		virtual JsonNodeBase* Generate(JsonNodeBase* parent,string _name) 
		{ 
			if (!parent) JsonError((char*)"Cannot produce a node with no parent");
			JsonNodeBase* nn=NewNode(Document,this,_name); 
			if (!nn) JsonError((char*)"Cannot produce a ",_name.c_str());
			appendChild(nn);
			return nn;
		}
		virtual const JsonNode* Root() 
			{if (!Parent()) return this; else return GetParent().Root();}
		JsonNode& GetParent()
		{
			const JsonNodeBase* _p=Parent(); 
			if (!_p) JsonError("Can't get a reference to a null parent");
			const JsonFamilyUtils::JsonNodeGuts* p=static_cast<const JsonFamilyUtils::JsonNodeGuts*>(_p); 
			const JsonNode* gp=static_cast<const JsonNode*>(p);
			return *const_cast<JsonNode*>(gp);
		}	

		virtual bool operator()() 
		{
			for (JsonFamily::JsonNodeSet::iterator it=children.begin();it!=children.end();it++) 
			{
				JsonNode& n=static_cast<JsonNode&>(*(*it));
				if (!n()) return false;
			}
			return true;
		}

		virtual bool operator()(ostream& o) 
		{
			for (JsonFamily::JsonNodeSet::iterator it=children.begin();it!=children.end();it++) 
			{
				JsonNode& n=static_cast<JsonNode&>(*(*it));
				if (!n(o)) return false;
			}
			return true;
		}

		virtual bool operator()(stringtype& s) 
		{
			for (JsonFamily::JsonNodeSet::iterator it=children.begin();it!=children.end();it++) 
			{
				JsonNode& n=static_cast<JsonNode&>(*(*it));
				if (!n(s)) return false;
			}
			return true;
		}


		virtual bool operator()(int& ndx, stringtype& s) 
		{
			for (JsonFamily::JsonNodeSet::iterator it=children.begin();it!=children.end();it++) 
			{
				JsonNode& n=static_cast<JsonNode&>(*(*it));
				if (!n(ndx,s)) return false;
			}
			return true;
		}

		virtual bool operator()(JsonNode& x) 
		{
			for (JsonFamily::JsonNodeSet::iterator it=children.begin();it!=children.end();it++) 
			{
				JsonNode& n=static_cast<JsonNode&>(*(*it));
				if (!n(x)) return false;
			}
			return true;
		}

		virtual ~JsonNode() {}
		virtual JsonNode& GetNode(string _name)
		{
			for (JsonFamily::JsonNodeSet::iterator it=children.begin();it!=children.end();it++) 
			{
				JsonNode& n=static_cast<JsonNode&>(*(*it));
				if (n.name==_name) return n;
			}
			stringstreamtype ss; ss<<"Cannot find "<<_name<<" in "<<name<<endl;
			JsonError((char*)ss.str().c_str());
			return DeadRoot();
		}
		
		virtual JsonNode* FindNode(string _name)
		{
			for (JsonFamily::JsonNodeSet::iterator it=children.begin();it!=children.end();it++) 
			{
				JsonNode& n=static_cast<JsonNode&>(*(*it));
				if (n.name==_name) return static_cast<JsonNode*>(*it);
			}
			return NULL;
		}

		virtual bool Exists(string _name)
		{
			for (JsonFamily::JsonNodeSet::iterator it=children.begin();it!=children.end();it++) 
			{
				JsonNode& n=static_cast<JsonNode&>(*(*it));
				if (n.name==_name) return true;
			}
			return false;
		}
		virtual JsonNode& RequireNode(string _name)
		{
			if (!Exists(_name)) Generate(this,_name);
			return GetNode(_name);
		}
		virtual void
			operator+=(stringtype line) 
				{ 
