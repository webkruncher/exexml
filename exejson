	class JsonNodeGuts : public JsonFamily::JsonNodeBase
	{
		friend class JsonFamily::Json;
	public:
		JsonNodeGuts(JsonFamily::Json& _doc,const JsonNodeBase* _parent,stringtype _name) : 
			JsonNodeBase(_doc,_parent),
			__tablevel(0),
			textsegments(_doc,_parent),
			name(_name), 
			children(false),// control lifetimes of children - not references here
			attributes(_doc,_parent)
		{ } 
		virtual ~JsonNodeGuts() {clear();name.clear();textmarkers.clear();}
		JsonNodeGuts& operator=(const JsonNodeGuts& a) 
		{
			if (&a==this) return *this; 
			clear();  
			return (JsonNodeGuts&)Copy((const JsonNodeBase&)a);
		}
		int __tablevel;

		virtual int TabLevel(){if (Parent()) return (GetParent().TabLevel()+1); else return __tablevel;}
		virtual int SetTabLevel(int tl){__tablevel=tl;return tl;}

		JsonFamily::TextSegments textsegments;
		stringtype name;
		JsonFamily::JsonNodeSet children;
		JsonFamily::JsonAttributes attributes;
		virtual stringtype& Name(){return name;}
		virtual JsonFamily::JsonAttributes& Attributes(){return attributes;}
		virtual void Load(stringtype& text)
		{
cerr << "Loading text" << endl;
			if (!text.size()) JsonError("malformed Json - no text");

			size_t firstnotwhite( text.find_first_not_of( whitespaces ) );
			char whatitis( text[ firstnotwhite ] );
			string shouldnotendwith( ( whatitis == '{' ) ? string( whitespaces ) + "[" : string( whitespaces ) + "{" ) ;
			size_t lastnotwhite( text.find_last_not_of( shouldnotendwith ) );
			char whatitwas( text[ lastnotwhite ] );
			//cerr << "Starts with " << whatitis << endl;
			//cerr << "EndsWith with " << whatitwas << endl;
			size_t opener( text.find( whatitis ) );

			if ( ( whatitis == '{' ) && ( whatitwas != '}' ) ) JsonError("malformed Json" );
			if ( ( whatitis == '[' ) && ( whatitwas != ']' ) ) JsonError("malformed Json" );
			
			if ( opener  == stringtype::npos ) JsonError("malformed Json");
			if ( firstnotwhite != opener ) JsonError("malformed Json");

			JsonFamilyUtils::NodeMapper xmap;
			text.erase( lastnotwhite + 1, text.size() - lastnotwhite - 1 );
			text.erase( 0, firstnotwhite );

cerr << "TEXT:" << text << ";" << endl;
			xmap.excavate(text,0,text.size());
exit( 0 );
			if (xmap.begin()!=xmap.end()) Load(text,*xmap.begin());
		}
	        virtual void appendChild(JsonNodeBase* n){children.push_back(n);}
		JsonNodeGuts& GetParent()
		{
			const JsonNodeBase* p=Parent(); 
			if (!p) JsonError("Can't get a reference to a null parent");
			const JsonNodeGuts* gp=static_cast<const JsonNodeGuts*>(p);
			return *const_cast<JsonNodeGuts*>(gp);
		}	
		virtual void clear(){attributes.clear();textsegments.clear();children.clear();name="";}
	private:
		virtual JsonNodeBase& Copy(const JsonNodeBase& _a)
		{
			JsonNodeGuts& a((JsonNodeGuts&)_a);
			name=a.name;
			__tablevel=a.__tablevel;
			attributes=a.attributes;
			textsegments=a.textsegments;
			JsonFamily::JsonNodeSet& ac=(JsonFamily::JsonNodeSet&)a.children;

			for (JsonFamily::JsonNodeSet::iterator it=ac.begin();it!=ac.end();it++)
			{
				JsonNodeBase& that((JsonNodeBase&)**it);
				JsonFamily::JsonNodeBase* c=(JsonFamily::JsonNodeBase*)
					that.NewNode(Document,this,"");				
				if (!c) JsonError("out of memory");
				c->Copy(that);
				appendChild(c);
			}
			return *this;
		}
	protected:
		virtual void tabs(int tl,ostream& o) { for (int i=0;i<(TabLevel()+tl);i++) o<<tab;}



		virtual void operator()(istream& i,ostream& o) 
		{
			for (JsonFamily::JsonNodeSet::iterator 
				it=children.begin();it!=children.end();it++)
			{
				if (*it) (*it)->operator()(i,o);
			}
		}
		virtual ostream& operator<<(ostream& o)
		{
			tabs(0,o); o<<"<"<<name.c_str();
			{
				if (attributes.size()) o<<" ";
				for(JsonFamily::JsonAttributes::iterator it=attributes.begin();
					it!=attributes.end();it++)
				{
					o<<endl;
					tabs(1,o);
					o<<it->first.c_str()<<"="<<"\""<<it->second.c_str()<<"\"";
				}
				if (attributes.size()) {o<<endl;tabs(0,o);}
			}
			if (children.size())
			{
				int ndx(0);
				o<<">";
				for (JsonFamily::JsonNodeSet::iterator 
					it=children.begin();it!=children.end();it++)
				{
					if (textsegments.find(ndx)!=textsegments.end()) o<<textsegments[ndx];
					if (*it) (*it)->operator<<(o);
					ndx++;
				}
				while (textsegments.find(ndx)!=textsegments.end()) {o<<textsegments[ndx]; ndx++;}
				tabs(0,o); 
				o<<"</"<<name.c_str()<<">";
			} else {
				if (textsegments.size())
				{
					o<<">"; o<<textsegments; 
					o<<"</"<<name.c_str()<<">";
				}  else 
					o<<" />";
			}
			return o;
		}
